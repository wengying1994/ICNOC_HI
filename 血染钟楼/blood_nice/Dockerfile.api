FROM node:22-alpine

WORKDIR /app

COPY package.json .
RUN npm install --omit=dev

COPY server.js .
COPY blood-nginx.conf /etc/nginx/conf.d/default.conf
COPY src/ /usr/share/nginx/html/

# nginx 反向代理到 node API
RUN echo '#!/bin/sh' > /start.sh && \
    echo 'nginx &' >> /start.sh && \
    echo 'node server.js &' >> /start.sh && \
    echo 'wait' >> /start.sh

EXPOSE 80 3000

CMD ["sh", "/start.sh"]
